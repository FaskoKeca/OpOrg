@model List<Operation>

@{
    ViewData["Title"] = "Operations";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Операции</h1>
        </div>
        <div class="col-md-6 text-end">
            <form asp-action="Search" method="post" class="d-inline-flex" style="width: 300px;">
                <input type="search" name="searchString" class="form-control me-2" placeholder="Търси операция..." />
                <button type="submit" class="btn btn-outline-primary">Търси</button>
            </form>
            <a asp-action="Create" class="btn btn-primary ms-2">+ Добави операция</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Няма операции.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Име</th>
                    <th>Дата</th>
                    <th>Статус</th>
                    <th>Цена</th>
                    <th>Консултации</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var operation in Model)
                {
                    <tr>
                        <td>@operation.Name</td>
                        <td>@operation.DateTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-@(operation.Status == "Pending" ? "warning" : operation.Status == "Approved" ? "success" : "danger")">
                                @(operation.Status == "Pending" ? "Очаквано" : operation.Status == "Approved" ? "Одобрено" : "Отхвърлено")
                            </span>
                        </td>
                        <td>@operation.Price.ToString("0.00") €</td>
                        <td>
                            <a asp-action="Consultations" asp-route-id="@operation.Id" class="badge bg-info text-decoration-none">@operation.Consultations.Count</a>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@operation.Id" class="btn btn-sm btn-info">Виж</a>
                            <a asp-action="Edit" asp-route-id="@operation.Id" class="btn btn-sm btn-warning">Редактирай</a>
                            <a asp-action="Delete" asp-route-id="@operation.Id" class="btn btn-sm btn-danger">Изтрий</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
