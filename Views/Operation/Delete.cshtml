@model Operation

@{
    ViewData["Title"] = "Delete Operation";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger">
                <h3>Вие сигурни ли че желаете да изтриете тази операция?</h3>
            </div>

            <dl class="row">
                <dt class="col-sm-2">Име:</dt>
                <dd class="col-sm-10">@Model.Name</dd>
                <dt class="col-sm-2">Дата:</dt>
                <dd class="col-sm-10">@Model.DateTime.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-2">Цена:</dt>
                <dd class="col-sm-10">@Model.Price.ToString("0.00") €</dd>
            </dl>

            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-secondary">Отмени</a>
            </form>
        </div>
    </div>
</div>
