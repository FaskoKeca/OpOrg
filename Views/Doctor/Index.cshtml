@model List<Doctor>

@{
    ViewData["Title"] = "Doctors";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Лекари</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">+ Добави лекар</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Няма регистрирани лекари.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Име</th>
                    <th>УИН</th>
                    <th>Операции</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doctor in Model)
                {
                    <tr>
                        <td>@doctor.Name</td>
                        <td>@doctor.UIN</td>
                        <td>@doctor.Operations.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-sm btn-info">Виж</a>
                            <a asp-action="Edit" asp-route-id="@doctor.Id" class="btn btn-sm btn-warning">Редактирай</a>
                            <a asp-action="Delete" asp-route-id="@doctor.Id" class="btn btn-sm btn-danger">Изтрий</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
