@model Doctor

@{
    ViewData["Title"] = "Doctor Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>@Model.Name</h1>
            <hr />
            
            <dl class="row">
                <dt class="col-sm-2">УИН:</dt>
                <dd class="col-sm-10">@Model.UIN</dd>
                <dt class="col-sm-2">Операции:</dt>
                <dd class="col-sm-10">@Model.Operations.Count</dd>
            </dl>

            <h3>Операции</h3>
            @if (Model.Operations.Count == 0)
            {
                <p>Няма операции за този лекар.</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var operation in Model.Operations)
                    {
                        <li class="list-group-item">
                            <strong>@operation.Name</strong> - @operation.DateTime.ToString("dd/MM/yyyy HH:mm")
                            <a asp-controller="Operation" asp-action="Details" asp-route-id="@operation.Id" class="btn btn-sm btn-info float-end">Виж</a>
                        </li>
                    }
                </ul>
            }

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактирай</a>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </div>
    </div>
</div>
