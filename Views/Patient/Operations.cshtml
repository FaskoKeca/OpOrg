@model List<Operation>

@{
    ViewData["Title"] = "Patient Operations";
    var patientId = ViewBag.PatientId ?? (Model.FirstOrDefault()?.PatientId ?? 0);
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Операции</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Operation" asp-action="Create" class="btn btn-primary">+ Добави операция</a>
            <a asp-controller="Patient" asp-action="Details" asp-route-id="@patientId" class="btn btn-secondary">Назад</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Няма операции за този пациент.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Име</th>
                    <th>Дата</th>
                    <th>Статус</th>
                    <th>Цена</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var operation in Model)
                {
                    <tr>
                        <td>@operation.Name</td>
                        <td>@operation.DateTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-@(operation.Status == "Pending" ? "warning" : operation.Status == "Approved" ? "success" : "danger")">
                                @(operation.Status == "Pending" ? "Очаквано" : operation.Status == "Approved" ? "Одобрено" : "Отхвърлено")
                            </span>
                        </td>
                        <td>@operation.Price.ToString("0.00") €</td>
                        <td>
                            <a asp-controller="Operation" asp-action="Details" asp-route-id="@operation.Id" class="btn btn-sm btn-info">Виж</a>
                            <a asp-controller="Operation" asp-action="Edit" asp-route-id="@operation.Id" class="btn btn-sm btn-warning">Редактирай</a>
                            <a asp-controller="Operation" asp-action="Delete" asp-route-id="@operation.Id" class="btn btn-sm btn-danger">Изтрий</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
