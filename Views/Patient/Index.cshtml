@model List<Patient>

@{
    ViewData["Title"] = "Patients";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Пациенти</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">+ Добави пациент</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Няма регистрирани пациенти.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Име</th>
                    <th>Операции</th>
                    <th>События</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var patient in Model)
                {
                    <tr>
                        <td>@patient.Name</td>
                        <td>@patient.Operations.Count</td>
                        <td>@patient.Events.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-sm btn-info">Виж</a>
                            <a asp-action="Edit" asp-route-id="@patient.Id" class="btn btn-sm btn-warning">Редактирай</a>
                            <a asp-action="Delete" asp-route-id="@patient.Id" class="btn btn-sm btn-danger">Изтрий</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
